# ── Base de datos: Supabase (PostgreSQL) ──────────────────────────────────────
# DATABASE_URL: pooler de transacciones (puerto 6543) — usado por la app.
#   Supabase → Project Settings → Database → Connection string → "Transaction pooler"
DATABASE_URL=postgres://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# DIRECT_URL: conexión directa/sesión (puerto 5432) — usada por drizzle-kit (migraciones).
#   Supabase → "Session pooler" o "Direct connection"
DIRECT_URL=postgres://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────────
# Genera un secreto aleatorio seguro (mín. 32 caracteres): openssl rand -base64 32
BETTER_AUTH_SECRET=cambia-esto-por-un-secreto-seguro-de-32-caracteres

# URL pública HTTPS de la app (sin barra al final). En Vercel: https://tu-proyecto.vercel.app
BETTER_AUTH_URL=https://tu-proyecto.vercel.app

# ── Email (opcional) — recordatorios de citas ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu-app-password
SMTP_FROM=Alma Veterinaria <noreply@tudominio.com>
