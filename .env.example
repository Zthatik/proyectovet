# Base de datos MySQL
# En Railway: copia el valor de DATABASE_URL del servicio MySQL
DATABASE_URL=mysql://user:password@host:3306/vetclinic

# Auth — genera un secreto aleatorio seguro (mín. 32 caracteres)
# Comando: openssl rand -base64 32
BETTER_AUTH_SECRET=cambia-esto-por-un-secreto-seguro-de-32-caracteres

# URL pública de la app (sin barra al final)
# En Railway: https://tu-proyecto.up.railway.app
BETTER_AUTH_URL=https://tu-proyecto.up.railway.app

# Puerto — Railway lo asigna automáticamente, no modificar en producción
# PORT=4321

# Email (opcional) — para recordatorios de citas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=tu-app-password
SMTP_FROM=VetClinic <noreply@tudominio.com>
