---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <div class="min-h-screen flex items-center justify-center bg-muted/30 px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <img src="/logo-alma-tagline.png" alt="Alma Veterinaria" class="w-72 max-w-full mx-auto" />
      </div>
      <div class="bg-card rounded-xl border shadow-sm p-6">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>
