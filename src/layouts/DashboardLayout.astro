---
import BaseLayout from './BaseLayout.astro';
import { DashboardShell } from '../components/layout/DashboardShell';
import { getNavItems } from '../lib/permissions';
import { db } from '../db';
import { users } from '../db/schema/users';
import { eq } from 'drizzle-orm';

interface Props {
  title: string;
  pageTitle?: string;
}

const { title, pageTitle } = Astro.props;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

// Fetch fresh name from DB so sidebar reflects edits without re-login
const [freshUser] = await db.select({ name: users.name, role: users.role })
  .from(users)
  .where(eq(users.id, user.id));

const navItems = getNavItems(user.role as any);
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title}>
  <DashboardShell
    client:load
    navItems={navItems}
    currentPath={currentPath}
    pageTitle={pageTitle || title}
    userName={freshUser?.name ?? user.name}
    userRole={freshUser?.role ?? user.role}
  >
    <slot />
  </DashboardShell>
</BaseLayout>
