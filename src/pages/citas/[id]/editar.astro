---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { AppointmentForm } from '../../../components/appointments/AppointmentForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const id = Number(Astro.params.id);
---

<DashboardLayout title="Editar Cita" pageTitle="Editar Cita">
  <div class="mb-6">
    <a href={`/citas/${id}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Volver a la Cita</a>
  </div>
  <div class="rounded-xl border bg-card p-6">
    <AppointmentForm client:load appointmentId={id} />
  </div>
</DashboardLayout>
