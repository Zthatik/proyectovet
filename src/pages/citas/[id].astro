---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db } from '../../db';
import { appointments } from '../../db/schema/appointments';
import { patients, owners } from '../../db/schema/patients';
import { users } from '../../db/schema/users';
import { eq } from 'drizzle-orm';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const id = Number(Astro.params.id);
const [appt] = await db
  .select({
    id: appointments.id, scheduledAt: appointments.scheduledAt, endAt: appointments.endAt,
    type: appointments.type, status: appointments.status, reason: appointments.reason,
    notes: appointments.notes, visitAddress: appointments.visitAddress,
    patientId: appointments.patientId, patientName: patients.name, patientSpecies: patients.species,
    ownerId: appointments.ownerId, ownerFirstName: owners.firstName, ownerLastName: owners.lastName, ownerPhone: owners.phone,
    veterinarianId: appointments.veterinarianId, veterinarianName: users.name,
  })
  .from(appointments)
  .leftJoin(patients, eq(appointments.patientId, patients.id))
  .leftJoin(owners, eq(appointments.ownerId, owners.id))
  .leftJoin(users, eq(appointments.veterinarianId, users.id))
  .where(eq(appointments.id, id));

if (!appt) return Astro.redirect('/citas');

const typeLabels: Record<string, string> = {
  consulta: 'Consulta', vacunacion: 'Vacunación', cirugia: 'Cirugía',
  control: 'Control', emergencia: 'Emergencia', grooming: 'Grooming',
};

const statusColors: Record<string, string> = {
  programada: 'bg-blue-100 text-blue-700', confirmada: 'bg-cyan-100 text-cyan-700',
  en_camino: 'bg-purple-100 text-purple-700', en_curso: 'bg-yellow-100 text-yellow-700',
  completada: 'bg-green-100 text-green-700', cancelada: 'bg-red-100 text-red-700',
  no_asistio: 'bg-gray-100 text-gray-600',
};

const statusLabels: Record<string, string> = {
  programada: 'Programada', confirmada: 'Confirmada', en_camino: 'En camino',
  en_curso: 'En curso', completada: 'Completada', cancelada: 'Cancelada', no_asistio: 'No asistió',
};

const isActive = !['completada', 'cancelada', 'no_asistio'].includes(appt.status);
const canBill  = user.role === 'admin' || user.role === 'recepcionista';
const canAct   = user.role === 'admin' || user.role === 'recepcionista';
const canMed   = user.role === 'admin' || user.role === 'veterinario';
---

<DashboardLayout title="Detalle de Cita" pageTitle="Detalle de Cita">
  <div class="mb-4">
    <a href="/citas" class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Volver a Citas</a>
  </div>

  <div class="max-w-2xl space-y-4">
    <div class="rounded-xl border bg-card p-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h2 class="text-xl font-bold">{typeLabels[appt.type] || appt.type}</h2>
          <p class="text-muted-foreground text-sm">
            {format(new Date(appt.scheduledAt), "EEEE dd 'de' MMMM yyyy, HH:mm", { locale: es })}
            {' – '}
            {format(new Date(appt.endAt), 'HH:mm', { locale: es })}
          </p>
        </div>
        <span class={`px-3 py-1 rounded-full text-xs font-medium ${statusColors[appt.status] || 'bg-gray-100'}`}>
          {statusLabels[appt.status] || appt.status}
        </span>
      </div>

      <dl class="space-y-3 text-sm">
        <div class="flex justify-between border-b pb-2">
          <dt class="text-muted-foreground">Paciente</dt>
          <dd><a href={`/pacientes/${appt.patientId}`} class="text-primary hover:underline">{appt.patientName}</a></dd>
        </div>
        <div class="flex justify-between border-b pb-2">
          <dt class="text-muted-foreground">Tutor</dt>
          <dd>{appt.ownerFirstName} {appt.ownerLastName} {appt.ownerPhone ? `· ${appt.ownerPhone}` : ''}</dd>
        </div>
        <div class="flex justify-between border-b pb-2">
          <dt class="text-muted-foreground">Veterinario</dt>
          <dd>{appt.veterinarianName || '—'}</dd>
        </div>
        {appt.visitAddress && (
          <div class="flex items-start justify-between gap-4 border-b pb-2">
            <dt class="text-muted-foreground shrink-0">Dirección visita</dt>
            <dd class="text-right">
              <span>{appt.visitAddress}</span>
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(appt.visitAddress)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="block text-xs text-primary hover:underline mt-0.5"
              >
                Ver en Google Maps ↗
              </a>
            </dd>
          </div>
        )}
        {appt.reason && (
          <div class="flex justify-between border-b pb-2">
            <dt class="text-muted-foreground">Motivo</dt>
            <dd>{appt.reason}</dd>
          </div>
        )}
        {appt.notes && (
          <div>
            <dt class="text-muted-foreground mb-1">Notas</dt>
            <dd class="text-sm">{appt.notes}</dd>
          </div>
        )}
      </dl>

      <!-- Cambio rápido de estado -->
      {canAct && isActive && (
        <div class="mt-4 pt-4 border-t">
          <p class="text-xs text-muted-foreground mb-2">Cambiar estado:</p>
          <div class="flex flex-wrap gap-2">
            {appt.status !== 'confirmada' && (
              <button class="status-btn text-xs px-3 py-1.5 rounded-full border bg-cyan-50 text-cyan-700 hover:bg-cyan-100 transition-colors" data-status="confirmada">Confirmar</button>
            )}
            {appt.status !== 'en_camino' && (
              <button class="status-btn text-xs px-3 py-1.5 rounded-full border bg-purple-50 text-purple-700 hover:bg-purple-100 transition-colors" data-status="en_camino">En camino</button>
            )}
            {appt.status !== 'en_curso' && (
              <button class="status-btn text-xs px-3 py-1.5 rounded-full border bg-yellow-50 text-yellow-700 hover:bg-yellow-100 transition-colors" data-status="en_curso">En curso</button>
            )}
            {appt.status !== 'completada' && (
              <button class="status-btn text-xs px-3 py-1.5 rounded-full border bg-green-50 text-green-700 hover:bg-green-100 transition-colors" data-status="completada">Completada</button>
            )}
            <button class="status-btn text-xs px-3 py-1.5 rounded-full border bg-red-50 text-red-700 hover:bg-red-100 transition-colors" data-status="cancelada">Cancelar</button>
          </div>
        </div>
      )}

      <!-- Acciones principales -->
      <div class="mt-6 flex gap-3 flex-wrap">
        {canMed && (
          <a href={`/historial/nuevo?patientId=${appt.patientId}&appointmentId=${appt.id}`}
            class="flex-1 text-center text-sm px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
            Registrar consulta
          </a>
        )}
        {canBill && (
          <a href={`/facturacion/nueva?ownerId=${appt.ownerId}&appointmentId=${appt.id}`}
            class="flex-1 text-center text-sm px-4 py-2 rounded-lg border border-primary text-primary hover:bg-primary/5 transition-colors font-medium">
            💳 Cobrar visita
          </a>
        )}
        <a href={`/citas/${id}/editar`}
          class="px-4 py-2 rounded-lg border text-sm hover:bg-muted transition-colors">
          Editar
        </a>
        {canAct && isActive && (
          <button id="btn-remind"
            class="px-4 py-2 rounded-lg border text-sm hover:bg-muted transition-colors">
            📧 Recordatorio
          </button>
        )}
      </div>
    </div>
  </div>
</DashboardLayout>

<script define:vars={{ apptId: id }}>
  const remindBtn = document.getElementById('btn-remind');
  if (remindBtn) {
    remindBtn.addEventListener('click', () => {
      remindBtn.disabled = true;
      remindBtn.textContent = 'Enviando...';
      fetch('/api/appointments/' + apptId + '/remind', { method: 'POST' })
        .then(r => r.json())
        .then(d => { remindBtn.textContent = d.success ? '✓ Enviado' : 'Error'; })
        .catch(() => { remindBtn.textContent = 'Error'; remindBtn.disabled = false; });
    });
  }
  document.querySelectorAll('.status-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      btn.disabled = true;
      btn.textContent = 'Guardando...';
      fetch('/api/appointments/' + apptId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: btn.dataset.status }),
      }).then(function() { window.location.reload(); });
    });
  });
</script>
