---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { InvoiceList } from '../../components/billing/InvoiceList';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');
---

<DashboardLayout title="Facturación" pageTitle="Facturación">
  {(user.role === 'admin' || user.role === 'recepcionista') && (
    <div class="flex justify-end mb-4">
      <a href="/facturacion/reportes" class="flex items-center gap-2 text-sm px-4 py-2 bg-primary text-primary-foreground rounded-lg font-medium hover:bg-primary/90 transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Ver Reportes
      </a>
    </div>
  )}
  <InvoiceList client:load />
</DashboardLayout>
