---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { StatCard } from '../../components/dashboard/StatCard';
import { VaccineReminders } from '../../components/dashboard/VaccineReminders';
import { NextAppointment } from '../../components/dashboard/NextAppointment';
import { ExpiringProducts } from '../../components/dashboard/ExpiringProducts';
import { PendingInvoices } from '../../components/dashboard/PendingInvoices';
import { ClientPortal } from '../../components/dashboard/ClientPortal';
import { PawPrint, Calendar, Package, Receipt } from 'lucide-react';
import { db } from '../../db';
import { patients, owners } from '../../db/schema/patients';
import { appointments } from '../../db/schema/appointments';
import { products } from '../../db/schema/inventory';
import { invoices } from '../../db/schema/billing';
import { eq, gte, and, count, sum, lt } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const roleGreeting: Record<string, string> = {
  admin: 'Panel de Administración',
  veterinario: 'Panel del Veterinario',
  recepcionista: 'Panel de Recepción',
  cliente: 'Mi Portal',
};

const isCliente = user.role === 'cliente';

// Only load staff stats for non-client roles
let patientCount = { count: 0 };
let todayAppts = { count: 0 };
let productCount = { count: 0 };
let revenue = 0;
let todayRoute: { id: number; scheduledAt: Date; type: string; status: string; visitAddress: string | null; patientName: string | null; ownerFirstName: string | null; ownerLastName: string | null; }[] = [];

if (!isCliente) {
  const today = new Date(); today.setHours(0, 0, 0, 0);
  const tomorrow = new Date(today); tomorrow.setDate(tomorrow.getDate() + 1);
  const firstOfMonth = new Date(today.getFullYear(), today.getMonth(), 1);

  // Las 5 consultas son independientes → se ejecutan en paralelo para reducir latencia.
  const [patientRes, apptRes, productRes, revenueRes, routeRes] = await Promise.all([
    db.select({ count: count() }).from(patients).where(eq(patients.isActive, true)),
    db.select({ count: count() }).from(appointments)
      .where(and(gte(appointments.scheduledAt, today), lt(appointments.scheduledAt, tomorrow))),
    db.select({ count: count() }).from(products).where(eq(products.isActive, true)),
    db.select({ total: sum(invoices.total) }).from(invoices)
      .where(and(gte(invoices.date, firstOfMonth), eq(invoices.status, 'pagada'))),
    db.select({
      id: appointments.id,
      scheduledAt: appointments.scheduledAt,
      type: appointments.type,
      status: appointments.status,
      visitAddress: appointments.visitAddress,
      patientName: patients.name,
      ownerFirstName: owners.firstName,
      ownerLastName: owners.lastName,
    }).from(appointments)
      .leftJoin(patients, eq(appointments.patientId, patients.id))
      .leftJoin(owners, eq(appointments.ownerId, owners.id))
      .where(and(gte(appointments.scheduledAt, today), lt(appointments.scheduledAt, tomorrow)))
      .orderBy(appointments.scheduledAt),
  ]);

  [patientCount] = patientRes;
  [todayAppts] = apptRes;
  [productCount] = productRes;
  todayRoute = routeRes;
  const monthRevenue = revenueRes[0];
  revenue = monthRevenue.total ? parseFloat(String(monthRevenue.total)) : 0;
}

const typeLabels: Record<string, string> = {
  consulta: 'Consulta', vacunacion: 'Vacunación', cirugia: 'Cirugía',
  control: 'Control', emergencia: 'Emergencia', grooming: 'Grooming',
};
const statusColors: Record<string, string> = {
  programada: 'bg-blue-100 text-blue-700', confirmada: 'bg-cyan-100 text-cyan-700',
  en_camino: 'bg-purple-100 text-purple-700', en_curso: 'bg-yellow-100 text-yellow-700',
  completada: 'bg-green-100 text-green-700', cancelada: 'bg-red-100 text-red-700',
};
---

<DashboardLayout title="Dashboard" pageTitle={roleGreeting[user.role] || 'Dashboard'}>
  <div class="space-y-6">
    <div>
      <h2 class="text-lg font-medium">Bienvenido, {user.name}</h2>
      <p class="text-muted-foreground text-sm">
        {isCliente ? 'Aquí puedes ver tus mascotas, citas y facturas.' : 'Aquí tienes un resumen de hoy.'}
      </p>
    </div>

    {isCliente ? (
      <ClientPortal client:load userName={user.name} />
    ) : (
      <>
        <div class="grid gap-6 grid-cols-2 [@media(min-width:1800px)]:grid-cols-4">
          <StatCard title="Pacientes" value={String(patientCount.count)}
            description="Registrados en el sistema" icon={PawPrint} href="/pacientes" />
          <StatCard title="Citas Hoy" value={String(todayAppts.count)}
            description="Programadas para hoy" icon={Calendar} href="/citas" />
          <StatCard title="Productos" value={String(productCount.count)}
            description="En inventario" icon={Package} href="/inventario" />
          <StatCard title="Facturación" value={`$${revenue.toLocaleString('es-CL')}`}
            description="Ingresos del mes" icon={Receipt} href="/facturacion" />
        </div>

        <!-- Próxima cita destacada -->
        <NextAppointment client:load />

        <div class="grid gap-4 grid-cols-1 lg:grid-cols-2">
          <!-- Ruta de Hoy -->
          <div class="rounded-xl border bg-card p-6">
            <div class="flex items-center justify-between mb-4">
              <div>
                <h3 class="font-semibold">🗺️ Ruta de Hoy</h3>
                <p class="text-xs text-muted-foreground mt-0.5">
                  {new Date().toLocaleDateString('es-CL', { weekday: 'long', day: 'numeric', month: 'long' })}
                </p>
              </div>
              <a href="/citas" class="text-xs text-primary hover:underline">Ver calendario</a>
            </div>
            {todayRoute.length === 0 ? (
              <p class="text-sm text-muted-foreground">No hay citas para hoy.</p>
            ) : (
              <div class="space-y-3">
                {todayRoute.map((a) => {
                  const mapsUrl = a.visitAddress
                    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(a.visitAddress + ', Talca, Chile')}`
                    : null;
                  return (
                    <div class={`border rounded-xl p-3 ${a.status === 'completada' ? 'opacity-60' : ''}`}>
                      <div class="flex items-start justify-between gap-2">
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-2 mb-1">
                            <span class="text-sm font-semibold">
                              {new Date(a.scheduledAt).toLocaleTimeString('es-CL', { hour: '2-digit', minute: '2-digit' })}
                            </span>
                            <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[a.status] || 'bg-gray-100'}`}>
                              {a.status.replace('_', ' ')}
                            </span>
                          </div>
                          <p class="text-sm font-medium">{a.patientName || '—'} <span class="text-muted-foreground font-normal">· {typeLabels[a.type] || a.type}</span></p>
                          <p class="text-xs text-muted-foreground">{a.ownerFirstName} {a.ownerLastName}</p>
                          {a.visitAddress && (
                            <div class="flex items-center gap-1.5 mt-1.5">
                              <svg class="h-3.5 w-3.5 text-muted-foreground shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
                              <span class="text-xs text-muted-foreground truncate">{a.visitAddress}</span>
                            </div>
                          )}
                        </div>
                        <div class="flex flex-col gap-1 shrink-0">
                          <a href={`/citas/${a.id}`} class="text-xs px-2 py-1 rounded-lg border hover:bg-muted transition-colors text-center">Ver</a>
                          {mapsUrl && (
                            <a href={mapsUrl} target="_blank" rel="noopener noreferrer"
                              class="text-xs px-2 py-1 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors text-center">
                              Maps
                            </a>
                          )}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            )}
          </div>

          <VaccineReminders client:visible />
        </div>

        <div class="grid gap-4 grid-cols-1 lg:grid-cols-2">
          <ExpiringProducts client:visible />
          <PendingInvoices client:visible />
        </div>

        <div class="rounded-xl border bg-card p-6">
          <h3 class="font-semibold mb-4">Accesos Rápidos</h3>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <a href="/pacientes/nuevo" class="flex items-center gap-2 border rounded-lg px-3 py-3 hover:bg-muted/30 transition-colors text-sm">
              <PawPrint class="h-4 w-4 text-primary" /> Nuevo Paciente
            </a>
            <a href="/citas/nueva" class="flex items-center gap-2 border rounded-lg px-3 py-3 hover:bg-muted/30 transition-colors text-sm">
              <Calendar class="h-4 w-4 text-primary" /> Nueva Cita
            </a>
            <a href="/facturacion/nueva" class="flex items-center gap-2 border rounded-lg px-3 py-3 hover:bg-muted/30 transition-colors text-sm">
              <Receipt class="h-4 w-4 text-primary" /> Nueva Factura
            </a>
            <a href="/inventario/nuevo" class="flex items-center gap-2 border rounded-lg px-3 py-3 hover:bg-muted/30 transition-colors text-sm">
              <Package class="h-4 w-4 text-primary" /> Nuevo Producto
            </a>
          </div>
          {(user.role === 'admin' || user.role === 'recepcionista') && (
            <div class="mt-3 pt-3 border-t flex items-center justify-between">
              <p class="text-xs text-muted-foreground">Enviar recordatorios por email para citas en las próximas 24 horas</p>
              <button id="btn-bulk-remind" class="text-xs px-3 py-1.5 rounded-lg border hover:bg-muted transition-colors">
                📧 Enviar recordatorios
              </button>
            </div>
          )}
        </div>
      </>
    )}
  </div>
</DashboardLayout>

<script>
  const btn = document.getElementById('btn-bulk-remind');
  if (btn) {
    btn.addEventListener('click', async () => {
      if (!confirm('¿Enviar recordatorios por email a los tutores con citas en las próximas 24 horas?')) return;
      btn.disabled = true;
      btn.textContent = '⏳ Enviando...';
      try {
        const res = await fetch('/api/appointments/reminders-bulk', { method: 'POST' });
        const d = await res.json();
        btn.textContent = `✓ ${d.sent} enviados${d.failed > 0 ? `, ${d.failed} fallaron` : ''}`;
      } catch {
        btn.textContent = 'Error al enviar';
        btn.disabled = false;
      }
    });
  }
</script>
