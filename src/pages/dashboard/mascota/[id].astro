---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { PetProfile } from '../../../components/dashboard/PetProfile';
import { db } from '../../../db';
import { owners, patients } from '../../../db/schema/patients';
import { appointments } from '../../../db/schema/appointments';
import { vaccines } from '../../../db/schema/medical';
import { prescriptions, prescriptionItems, labOrders } from '../../../db/schema/prescriptions';
import { users } from '../../../db/schema/users';
import { eq, and, desc, inArray } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

// Esta página es el portal del tutor. El staff usa /pacientes/[id].
if (user.role !== 'tutor') return Astro.redirect('/dashboard');

const petId = Number(Astro.params.id);
if (!Number.isInteger(petId) || petId <= 0) return Astro.redirect('/dashboard');

// Ficha del tutor vinculada a esta cuenta.
const [owner] = await db.select().from(owners).where(eq(owners.userId, user.id));
if (!owner) return Astro.redirect('/dashboard');

// La mascota debe pertenecer a este tutor (control de propiedad).
const [pet] = await db
  .select()
  .from(patients)
  .where(and(eq(patients.id, petId), eq(patients.ownerId, owner.id)));
if (!pet) return Astro.redirect('/dashboard');

// Datos clínicos de esta mascota, en paralelo.
const [apptList, vaccineList, rxList, labList] = await Promise.all([
  db
    .select({
      id: appointments.id,
      scheduledAt: appointments.scheduledAt,
      type: appointments.type,
      status: appointments.status,
      reason: appointments.reason,
      visitAddress: appointments.visitAddress,
      veterinarianName: users.name,
    })
    .from(appointments)
    .leftJoin(users, eq(appointments.veterinarianId, users.id))
    .where(eq(appointments.patientId, petId))
    .orderBy(desc(appointments.scheduledAt)),
  db
    .select({
      id: vaccines.id,
      name: vaccines.name,
      brand: vaccines.brand,
      applicationDate: vaccines.applicationDate,
      nextDoseDate: vaccines.nextDoseDate,
      notes: vaccines.notes,
      veterinarianName: users.name,
    })
    .from(vaccines)
    .leftJoin(users, eq(vaccines.veterinarianId, users.id))
    .where(eq(vaccines.patientId, petId))
    .orderBy(desc(vaccines.applicationDate)),
  db
    .select({
      id: prescriptions.id,
      date: prescriptions.date,
      status: prescriptions.status,
      notes: prescriptions.notes,
      veterinarianName: users.name,
    })
    .from(prescriptions)
    .leftJoin(users, eq(prescriptions.veterinarianId, users.id))
    .where(eq(prescriptions.patientId, petId))
    .orderBy(desc(prescriptions.date)),
  db
    .select({
      id: labOrders.id,
      type: labOrders.type,
      description: labOrders.description,
      status: labOrders.status,
      results: labOrders.results,
      requestedAt: labOrders.requestedAt,
      completedAt: labOrders.completedAt,
      veterinarianName: users.name,
    })
    .from(labOrders)
    .leftJoin(users, eq(labOrders.veterinarianId, users.id))
    .where(eq(labOrders.patientId, petId))
    .orderBy(desc(labOrders.requestedAt)),
]);

// Adjuntar medicamentos a cada receta.
let prescriptionsWithItems = rxList.map((rx) => ({ ...rx, items: [] as any[] }));
if (rxList.length > 0) {
  const items = await db
    .select()
    .from(prescriptionItems)
    .where(inArray(prescriptionItems.prescriptionId, rxList.map((r) => r.id)));
  prescriptionsWithItems = rxList.map((rx) => ({
    ...rx,
    items: items.filter((it) => it.prescriptionId === rx.id),
  }));
}

// Serializar fechas a ISO para pasar a la isla de React.
const petData = {
  ...pet,
  appointments: apptList.map((a) => ({ ...a, scheduledAt: a.scheduledAt.toISOString() })),
  vaccines: vaccineList,
  prescriptions: prescriptionsWithItems.map((rx) => ({ ...rx, date: rx.date.toISOString() })),
  labOrders: labList.map((lo) => ({
    ...lo,
    requestedAt: lo.requestedAt.toISOString(),
    completedAt: lo.completedAt ? lo.completedAt.toISOString() : null,
  })),
};
---

<DashboardLayout title={pet.name} pageTitle={pet.name}>
  <PetProfile client:load pet={petData} />
</DashboardLayout>
