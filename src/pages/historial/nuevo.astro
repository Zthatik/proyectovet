---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { MedicalRecordForm } from '../../components/medical/MedicalRecordForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');
if (user.role !== 'admin' && user.role !== 'veterinario') return Astro.redirect('/dashboard');

const patientId = Astro.url.searchParams.get('patientId');
const appointmentId = Astro.url.searchParams.get('appointmentId');
---

<DashboardLayout title="Nueva Consulta" pageTitle="Registrar Consulta Médica">
  <div class="mb-6">
    <a href={patientId ? `/pacientes/${patientId}` : '/pacientes'} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
      ← Volver
    </a>
  </div>
  <div class="rounded-xl border bg-card p-6">
    <MedicalRecordForm
      client:load
      patientId={patientId ? Number(patientId) : undefined}
      appointmentId={appointmentId ? Number(appointmentId) : undefined}
    />
  </div>
</DashboardLayout>
