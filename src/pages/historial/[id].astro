---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db } from '../../db';
import { medicalRecords } from '../../db/schema/medical';
import { patients, owners } from '../../db/schema/patients';
import { users } from '../../db/schema/users';
import { prescriptions } from '../../db/schema/prescriptions';
import { eq, desc } from 'drizzle-orm';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const id = Number(Astro.params.id);
const [record] = await db
  .select({
    id: medicalRecords.id,
    date: medicalRecords.date,
    reason: medicalRecords.reason,
    diagnosis: medicalRecords.diagnosis,
    treatment: medicalRecords.treatment,
    observations: medicalRecords.observations,
    vitalSigns: medicalRecords.vitalSigns,
    appointmentId: medicalRecords.appointmentId,
    patientId: medicalRecords.patientId,
    patientName: patients.name,
    patientSpecies: patients.species,
    patientBreed: patients.breed,
    ownerId: patients.ownerId,
    ownerFirstName: owners.firstName,
    ownerLastName: owners.lastName,
    veterinarianId: medicalRecords.veterinarianId,
    veterinarianName: users.name,
  })
  .from(medicalRecords)
  .leftJoin(patients, eq(medicalRecords.patientId, patients.id))
  .leftJoin(owners, eq(patients.ownerId, owners.id))
  .leftJoin(users, eq(medicalRecords.veterinarianId, users.id))
  .where(eq(medicalRecords.id, id));

if (!record) return Astro.redirect('/pacientes');

const rxList = await db
  .select({ id: prescriptions.id, date: prescriptions.date, status: prescriptions.status })
  .from(prescriptions)
  .where(eq(prescriptions.medicalRecordId, id))
  .orderBy(desc(prescriptions.date));

const vs = record.vitalSigns as { temperature?: number; heartRate?: number; weight?: number; respiratoryRate?: number } | null;

const canEdit = user.role === 'admin' || user.role === 'veterinario';

const rxStatusColors: Record<string, string> = {
  borrador: 'bg-gray-100 text-gray-600',
  activa: 'bg-green-100 text-green-700',
  completada: 'bg-blue-100 text-blue-700',
  cancelada: 'bg-red-100 text-red-700',
};
---

<DashboardLayout title="Consulta Médica" pageTitle="Registro de Consulta">
  <div class="mb-4 flex items-center justify-between">
    <a href={`/pacientes/${record.patientId}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
      ← Volver al expediente
    </a>
    {canEdit && (
      <a href={`/recetas/nueva?patientId=${record.patientId}&medicalRecordId=${id}`}
        class="text-sm px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
        + Nueva Receta
      </a>
    )}
  </div>

  <div class="max-w-3xl space-y-4">
    <!-- Header -->
    <div class="rounded-xl border bg-card p-6">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h2 class="text-xl font-bold">{record.reason}</h2>
          <p class="text-muted-foreground text-sm mt-1">
            {format(new Date(record.date), "EEEE dd 'de' MMMM yyyy, HH:mm", { locale: es })}
          </p>
        </div>
        <div class="text-right text-sm">
          <a href={`/pacientes/${record.patientId}`} class="font-medium text-primary hover:underline">
            {record.patientName}
          </a>
          <p class="text-muted-foreground capitalize">{record.patientSpecies}{record.patientBreed ? ` · ${record.patientBreed}` : ''}</p>
        </div>
      </div>

      <dl class="mt-4 space-y-1 text-sm border-t pt-4">
        <div class="flex justify-between">
          <dt class="text-muted-foreground">Dueño</dt>
          <dd>{record.ownerFirstName} {record.ownerLastName}</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-muted-foreground">Veterinario</dt>
          <dd>{record.veterinarianName || '—'}</dd>
        </div>
        {record.appointmentId && (
          <div class="flex justify-between">
            <dt class="text-muted-foreground">Cita relacionada</dt>
            <dd><a href={`/citas/${record.appointmentId}`} class="text-primary hover:underline">Ver cita</a></dd>
          </div>
        )}
      </dl>
    </div>

    <!-- Vital signs -->
    {vs && (vs.temperature || vs.heartRate || vs.weight || vs.respiratoryRate) && (
      <div class="rounded-xl border bg-card p-6">
        <h3 class="font-semibold mb-3">Signos Vitales</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {vs.temperature && (
            <div class="text-center p-3 bg-muted/30 rounded-lg">
              <p class="text-2xl font-bold">{vs.temperature}°</p>
              <p class="text-xs text-muted-foreground mt-1">Temperatura (°C)</p>
            </div>
          )}
          {vs.heartRate && (
            <div class="text-center p-3 bg-muted/30 rounded-lg">
              <p class="text-2xl font-bold">{vs.heartRate}</p>
              <p class="text-xs text-muted-foreground mt-1">F. Cardíaca (bpm)</p>
            </div>
          )}
          {vs.respiratoryRate && (
            <div class="text-center p-3 bg-muted/30 rounded-lg">
              <p class="text-2xl font-bold">{vs.respiratoryRate}</p>
              <p class="text-xs text-muted-foreground mt-1">F. Respiratoria (rpm)</p>
            </div>
          )}
          {vs.weight && (
            <div class="text-center p-3 bg-muted/30 rounded-lg">
              <p class="text-2xl font-bold">{vs.weight} kg</p>
              <p class="text-xs text-muted-foreground mt-1">Peso</p>
            </div>
          )}
        </div>
      </div>
    )}

    <!-- Clinical notes -->
    <div class="rounded-xl border bg-card p-6 space-y-4">
      <h3 class="font-semibold">Notas Clínicas</h3>

      {record.diagnosis && (
        <div>
          <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1">Diagnóstico</p>
          <p class="text-sm whitespace-pre-wrap">{record.diagnosis}</p>
        </div>
      )}

      {record.treatment && (
        <div>
          <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1">Tratamiento</p>
          <p class="text-sm whitespace-pre-wrap">{record.treatment}</p>
        </div>
      )}

      {record.observations && (
        <div>
          <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wide mb-1">Observaciones</p>
          <p class="text-sm whitespace-pre-wrap">{record.observations}</p>
        </div>
      )}

      {!record.diagnosis && !record.treatment && !record.observations && (
        <p class="text-sm text-muted-foreground">Sin notas adicionales registradas.</p>
      )}
    </div>

    <!-- Prescriptions -->
    <div class="rounded-xl border bg-card p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-semibold">Recetas Asociadas</h3>
        {canEdit && (
          <a href={`/recetas/nueva?patientId=${record.patientId}&medicalRecordId=${id}`}
            class="text-xs text-primary hover:underline">
            + Nueva receta
          </a>
        )}
      </div>
      {rxList.length === 0 ? (
        <p class="text-sm text-muted-foreground">Sin recetas generadas para esta consulta.</p>
      ) : (
        <div class="space-y-2">
          {rxList.map((rx) => (
            <a href={`/recetas/${rx.id}`}
              class="flex items-center justify-between border rounded-lg px-4 py-3 hover:bg-muted/30 transition-colors">
              <span class="text-sm font-medium">
                Receta #{rx.id} — {format(new Date(rx.date), 'dd/MM/yyyy', { locale: es })}
              </span>
              <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${rxStatusColors[rx.status] || 'bg-gray-100'}`}>
                {rx.status.charAt(0).toUpperCase() + rx.status.slice(1)}
              </span>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</DashboardLayout>
