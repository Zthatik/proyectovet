---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { OwnerForm } from '../../components/patients/OwnerForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');
---

<DashboardLayout title="Nuevo Tutor" pageTitle="Registrar Tutor">
  <div class="mb-6">
    <a href="/pacientes" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
      ← Volver a Pacientes
    </a>
  </div>
  <div class="rounded-xl border bg-card p-6">
    <h2 class="text-lg font-semibold mb-6">Datos del Tutor</h2>
    <OwnerForm client:load />
  </div>
</DashboardLayout>
