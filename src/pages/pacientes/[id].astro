---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { PatientProfileTabs } from '../../components/patients/PatientProfileTabs';
import { CoOwnersSection } from '../../components/patients/CoOwnersSection';
import { db } from '../../db';
import { patients, owners } from '../../db/schema/patients';
import { medicalRecords } from '../../db/schema/medical';
import { appointments } from '../../db/schema/appointments';
import { eq, desc } from 'drizzle-orm';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const id = Number(Astro.params.id);
const [patient] = await db
  .select({
    id: patients.id, name: patients.name, species: patients.species,
    breed: patients.breed, color: patients.color, sex: patients.sex,
    dateOfBirth: patients.dateOfBirth, weight: patients.weight,
    microchipNumber: patients.microchipNumber, notes: patients.notes,
    isActive: patients.isActive, ownerId: patients.ownerId,
    photo: patients.photo,
    ownerFirstName: owners.firstName, ownerLastName: owners.lastName,
    ownerEmail: owners.email, ownerPhone: owners.phone,
  })
  .from(patients)
  .leftJoin(owners, eq(patients.ownerId, owners.id))
  .where(eq(patients.id, id));

if (!patient) return Astro.redirect('/pacientes');

const records = await db.select().from(medicalRecords).where(eq(medicalRecords.patientId, id)).orderBy(desc(medicalRecords.date)).limit(30);
const appts = await db.select().from(appointments).where(eq(appointments.patientId, id)).orderBy(desc(appointments.scheduledAt)).limit(30);

const canEdit = user.role === 'admin' || user.role === 'veterinario';
const canManageOwners = user.role === 'admin' || user.role === 'recepcionista';
const speciesEmoji: Record<string, string> = { perro: '🐕', gato: '🐈', ave: '🐦', reptil: '🦎', roedor: '🐭', otro: '🐾' };
---

<DashboardLayout title={patient.name} pageTitle={`Paciente: ${patient.name}`}>
  <div class="mb-4">
    <a href="/pacientes" class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Volver a Pacientes</a>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <!-- Info principal -->
    <div class="lg:col-span-1 space-y-4">
      <div class="rounded-xl border bg-card p-6">
        <div class="flex items-start justify-between mb-4">
          <div class="w-20 h-20 rounded-2xl overflow-hidden border bg-muted flex items-center justify-center shrink-0">
            {patient.photo ? (
              <img src={patient.photo} alt={patient.name} class="w-full h-full object-cover" />
            ) : (
              <span class="text-4xl">{speciesEmoji[patient.species] || '🐾'}</span>
            )}
          </div>
          <span class={`px-2 py-1 rounded-full text-xs font-medium ${patient.isActive ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
            {patient.isActive ? 'Activo' : 'Inactivo'}
          </span>
        </div>
        <h2 class="text-xl font-bold">{patient.name}</h2>
        <p class="text-muted-foreground capitalize text-sm">{patient.species}{patient.breed ? ` · ${patient.breed}` : ''}</p>

        <dl class="mt-4 space-y-2 text-sm">
          <div class="flex justify-between"><dt class="text-muted-foreground">Sexo</dt><dd class="capitalize">{patient.sex}</dd></div>
          {patient.color && <div class="flex justify-between"><dt class="text-muted-foreground">Color</dt><dd>{patient.color}</dd></div>}
          {patient.weight && <div class="flex justify-between"><dt class="text-muted-foreground">Peso</dt><dd>{patient.weight} kg</dd></div>}
          {patient.dateOfBirth && <div class="flex justify-between"><dt class="text-muted-foreground">Nacimiento</dt><dd>{format(new Date(patient.dateOfBirth), 'dd/MM/yyyy', { locale: es })}</dd></div>}
          {patient.microchipNumber && <div class="flex justify-between"><dt class="text-muted-foreground">Microchip</dt><dd class="font-mono text-xs">{patient.microchipNumber}</dd></div>}
        </dl>

        <div class="mt-4 flex gap-2">
          <a href={`/pacientes/${id}/editar`} class="flex-1 text-center text-sm px-3 py-2 rounded-lg border hover:bg-muted transition-colors">Editar</a>
          <a href={`/citas/nueva?patientId=${id}`} class="flex-1 text-center text-sm px-3 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">Nueva Cita</a>
        </div>
      </div>

      <!-- Tutor -->
      <div class="rounded-xl border bg-card p-6">
        <h3 class="font-semibold mb-3">Tutor</h3>
        <a href={`/tutores/${patient.ownerId}`} class="font-medium text-primary hover:underline">{patient.ownerFirstName} {patient.ownerLastName}</a>
        {patient.ownerPhone && <p class="text-sm text-muted-foreground">{patient.ownerPhone}</p>}
        {patient.ownerEmail && <p class="text-sm text-muted-foreground">{patient.ownerEmail}</p>}
      </div>

      <CoOwnersSection client:load patientId={id} canEdit={canManageOwners} />

      {patient.notes && (
        <div class="rounded-xl border bg-card p-6">
          <h3 class="font-semibold mb-2">Notas</h3>
          <p class="text-sm text-muted-foreground">{patient.notes}</p>
        </div>
      )}
    </div>

    <!-- Historial -->
    <div class="lg:col-span-2">
      <PatientProfileTabs client:load patientId={id} canEdit={canEdit} records={records} appointments={appts} />
    </div>
  </div>
</DashboardLayout>
