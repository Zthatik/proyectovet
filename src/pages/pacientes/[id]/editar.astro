---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { PatientForm } from '../../../components/patients/PatientForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const id = Number(Astro.params.id);
---

<DashboardLayout title="Editar Paciente" pageTitle="Editar Paciente">
  <div class="mb-6">
    <a href={`/pacientes/${id}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
      ← Volver al Paciente
    </a>
  </div>
  <div class="rounded-xl border bg-card p-6">
    <h2 class="text-lg font-semibold mb-6">Editar Datos del Paciente</h2>
    <PatientForm client:load patientId={id} />
  </div>
</DashboardLayout>
