---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { db } from '../../db';
import { products, stockMovements } from '../../db/schema/inventory';
import { eq, desc } from 'drizzle-orm';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const id = Number(Astro.params.id);
const [product] = await db.select().from(products).where(eq(products.id, id));
if (!product) return Astro.redirect('/inventario');

const movements = await db.select().from(stockMovements).where(eq(stockMovements.productId, id)).orderBy(desc(stockMovements.createdAt)).limit(20);

const categoryLabels: Record<string, string> = {
  medicamento: 'Medicamento', vacuna: 'Vacuna', insumo: 'Insumo',
  alimento: 'Alimento', accesorio: 'Accesorio', otro: 'Otro',
};
---

<DashboardLayout title={product.name} pageTitle="Detalle de Producto">
  <div class="mb-4">
    <a href="/inventario" class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Volver a Inventario</a>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <div class="rounded-xl border bg-card p-6 lg:col-span-1 space-y-4">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="text-xl font-bold">{product.name}</h2>
          <p class="text-sm text-muted-foreground">{categoryLabels[product.category] || product.category}</p>
        </div>
        <span class={`px-2 py-1 rounded-full text-xs font-medium ${product.isActive ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
          {product.isActive ? 'Activo' : 'Inactivo'}
        </span>
      </div>

      {product.description && <p class="text-sm text-muted-foreground">{product.description}</p>}

      <dl class="space-y-2 text-sm">
        <div class="flex justify-between border-b pb-2">
          <dt class="text-muted-foreground">Precio venta</dt>
          <dd class="font-semibold">${parseFloat(product.unitPrice).toLocaleString('es-CL')}</dd>
        </div>
        {product.costPrice && (
          <div class="flex justify-between border-b pb-2">
            <dt class="text-muted-foreground">Precio costo</dt>
            <dd>${parseFloat(product.costPrice).toLocaleString('es-CL')}</dd>
          </div>
        )}
        <div class="flex justify-between border-b pb-2">
          <dt class="text-muted-foreground">Stock actual</dt>
          <dd class={`font-bold ${product.stock <= product.minStock ? 'text-red-600' : 'text-green-700'}`}>
            {product.stock} {product.unit}
          </dd>
        </div>
        <div class="flex justify-between border-b pb-2">
          <dt class="text-muted-foreground">Stock mínimo</dt>
          <dd>{product.minStock} {product.unit}</dd>
        </div>
        {product.sku && <div class="flex justify-between border-b pb-2"><dt class="text-muted-foreground">SKU</dt><dd class="font-mono text-xs">{product.sku}</dd></div>}
        {product.supplier && <div class="flex justify-between border-b pb-2"><dt class="text-muted-foreground">Proveedor</dt><dd>{product.supplier}</dd></div>}
        {product.expirationDate && (
          <div class="flex justify-between">
            <dt class="text-muted-foreground">Vence</dt>
            <dd>{format(new Date(product.expirationDate), 'dd/MM/yyyy', { locale: es })}</dd>
          </div>
        )}
      </dl>

      <div class="flex gap-2 pt-2">
        <a href={`/inventario/${id}/editar`} class="flex-1 text-center text-sm px-3 py-2 rounded-lg border hover:bg-muted transition-colors">Editar</a>
        <a href={`/inventario/${id}/stock`} class="flex-1 text-center text-sm px-3 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">Ajustar Stock</a>
      </div>
    </div>

    <div class="rounded-xl border bg-card p-6 lg:col-span-2">
      <h3 class="font-semibold mb-4">Movimientos de Stock</h3>
      {movements.length === 0 ? (
        <p class="text-sm text-muted-foreground">Sin movimientos registrados.</p>
      ) : (
        <div class="space-y-2">
          {movements.map((m) => (
            <div class="flex items-center justify-between border rounded-lg p-3 text-sm">
              <div>
                <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium mr-2 ${
                  m.type === 'entrada' ? 'bg-green-100 text-green-700' :
                  m.type === 'salida' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700'
                }`}>
                  {m.type === 'entrada' ? '+' : m.type === 'salida' ? '-' : '~'}{m.quantity}
                </span>
                {m.reason && <span class="text-muted-foreground">{m.reason}</span>}
              </div>
              <span class="text-xs text-muted-foreground">{format(new Date(m.createdAt), 'dd/MM/yyyy HH:mm', { locale: es })}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</DashboardLayout>
