---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { StockForm } from '../../../components/inventory/StockForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const id = Number(Astro.params.id);
---

<DashboardLayout title="Ajustar Stock" pageTitle="Ajustar Stock">
  <div class="mb-6">
    <a href={`/inventario/${id}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Volver al Producto</a>
  </div>
  <div class="rounded-xl border bg-card p-6 max-w-md">
    <h2 class="text-lg font-semibold mb-6">Movimiento de Stock</h2>
    <StockForm client:load productId={id} />
  </div>
</DashboardLayout>
