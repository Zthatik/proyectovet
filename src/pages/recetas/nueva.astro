---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { PrescriptionForm } from '../../components/prescriptions/PrescriptionForm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');
if (user.role !== 'admin' && user.role !== 'veterinario') return Astro.redirect('/recetas');

const patientId = Astro.url.searchParams.get('patientId');
const medicalRecordId = Astro.url.searchParams.get('medicalRecordId');
---

<DashboardLayout title="Nueva Receta" pageTitle="Emitir Receta">
  <div class="mb-6">
    <a href="/recetas" class="text-sm text-muted-foreground hover:text-foreground transition-colors">← Volver a Recetas</a>
  </div>
  <div class="rounded-xl border bg-card p-6">
    <PrescriptionForm
      client:load
      patientId={patientId ? Number(patientId) : undefined}
      medicalRecordId={medicalRecordId ? Number(medicalRecordId) : undefined}
    />
  </div>
</DashboardLayout>
